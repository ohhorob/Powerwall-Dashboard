{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "MikroTik powerwall-bridge router monitoring — WiFi signal, throughput, errors",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Powerwall WiFi Link (wlan1 → TEG-11W)",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "Disconnected" }, "1": { "color": "green", "index": 1, "text": "Connected" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "WiFi Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"connected\") FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "dBm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": -80 },
              { "color": "yellow", "value": -70 },
              { "color": "green",  "value": -60 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Signal Strength",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"signal_strength\") FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "dB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 15 },
              { "color": "yellow", "value": 25 },
              { "color": "green",  "value": 40 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Signal / Noise Ratio",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"signal_to_noise\") FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 70 },
              { "color": "green",  "value": 85 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "TX CCQ (Quality)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"tx_ccq\") FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "Mbps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "TX" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "WiFi Link Rates",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "RX",
          "query": "SELECT last(\"rx_rate_mbps\") FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "TX",
          "query": "SELECT last(\"tx_rate_mbps\") FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter",
          "rawQuery": true,
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "unit": "dBm"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Signal (dBm)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": -80 },
                    { "color": "yellow", "value": -70 },
                    { "color": "green", "value": -60 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["min", "mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "WiFi Signal Strength (wlan1 → Powerwall)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "Signal (dBm)",
          "query": "SELECT mean(\"signal_strength\") AS \"Signal (dBm)\" FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "SNR (dB)",
          "query": "SELECT mean(\"signal_to_noise\") AS \"SNR (dB)\" FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "unit": "none",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["min", "mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "TX CCQ — Transmission Quality %",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "TX CCQ %",
          "query": "SELECT mean(\"tx_ccq\") AS \"TX CCQ %\" FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Traffic Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "unit": "bps"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "TX.*" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "wlan1 Throughput (Powerwall WiFi)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "RX (from Powerwall)",
          "query": "SELECT mean(\"rx_bps\") AS \"RX\" FROM \"mikrotik_traffic\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "TX (to Powerwall)",
          "query": "SELECT mean(\"tx_bps\") AS \"TX\" FROM \"mikrotik_traffic\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "unit": "bps"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "TX.*" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "ether1 Throughput (LAN Uplink)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "RX",
          "query": "SELECT mean(\"rx_bps\") AS \"RX\" FROM \"mikrotik_traffic\" WHERE \"interface\" = 'ether1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "TX",
          "query": "SELECT mean(\"tx_bps\") AS \"TX\" FROM \"mikrotik_traffic\" WHERE \"interface\" = 'ether1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Errors & Drops",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "wlan1 Errors per Minute (WiFi Dropouts)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "RX Errors/min",
          "query": "SELECT non_negative_derivative(max(\"rx_errors\"), 1m) AS \"RX Errors/min\" FROM \"mikrotik_errors\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "TX Errors/min",
          "query": "SELECT non_negative_derivative(max(\"tx_errors\"), 1m) AS \"TX Errors/min\" FROM \"mikrotik_errors\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "RX Drops/min",
          "query": "SELECT non_negative_derivative(max(\"rx_drops\"), 1m) AS \"RX Drops/min\" FROM \"mikrotik_errors\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "TX Drops/min",
          "query": "SELECT non_negative_derivative(max(\"tx_drops\"), 1m) AS \"TX Drops/min\" FROM \"mikrotik_errors\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "D"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "All Interfaces — Errors per Minute",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "$tag_interface RX Err",
          "query": "SELECT non_negative_derivative(max(\"rx_errors\"), 1m) AS \"RX Errors/min\" FROM \"mikrotik_errors\" WHERE $timeFilter GROUP BY time($__interval), \"interface\" fill(0)",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "$tag_interface TX Err",
          "query": "SELECT non_negative_derivative(max(\"tx_errors\"), 1m) AS \"TX Errors/min\" FROM \"mikrotik_errors\" WHERE $timeFilter GROUP BY time($__interval), \"interface\" fill(0)",
          "rawQuery": true,
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "showPoints": "never",
            "fillOpacity": 5
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "title": "WiFi Connection Status (1=connected, 0=searching)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "alias": "Connected",
          "query": "SELECT mean(\"connected\") AS \"Connected\" FROM \"mikrotik_wifi\" WHERE \"interface\" = 'wlan1' AND $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mikrotik", "network", "powerwall"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "MikroTik — Powerwall Bridge",
  "uid": "mikrotik-powerwall-bridge",
  "version": 1
}
